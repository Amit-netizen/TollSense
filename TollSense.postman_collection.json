{
  "info": {
    "name": "TollSense API",
    "description": "Full API test collection for TollSense backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('token', res.access_token);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has access_token', () => pm.expect(res.access_token).to.be.a('string'));",
                  "pm.test('Has refresh_token', () => pm.expect(res.refresh_token).to.be.a('string'));",
                  "pm.test('Has user object', () => pm.expect(res.user).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@tollsense.io\", \"password\": \"admin123\"}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Login - Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Has error', () => pm.expect(pm.response.json().error).to.include('Invalid'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@tollsense.io\", \"password\": \"wrongpass\"}"
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Login - Missing Fields",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\": \"admin@tollsense.io\"}" },
            "url": "{{base_url}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Trips",
      "item": [
        {
          "name": "List Trips",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Has data array', () => pm.expect(body.data).to.be.an('array'));",
                  "pm.test('Has total', () => pm.expect(body.total).to.be.a('number'));",
                  "pm.test('Has page', () => pm.expect(body.page).to.be.a('number'));",
                  "if (body.data.length > 0) {",
                  "  pm.collectionVariables.set('trip_id', body.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/trips?page=1&per_page=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "List Trips - Filter Completed",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('All trips are completed', () => {",
                  "  body.data.forEach(t => pm.expect(t.status).to.equal('completed'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/api/trips?status=completed",
              "query": [{ "key": "status", "value": "completed" }]
            }
          }
        },
        {
          "name": "Get Trip by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const t = pm.response.json();",
                  "pm.test('Has origin', () => pm.expect(t.origin).to.be.a('string'));",
                  "pm.test('Has destination', () => pm.expect(t.destination).to.be.a('string'));",
                  "pm.test('Has status', () => pm.expect(t.status).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/trips/{{trip_id}}"
          }
        },
        {
          "name": "Get Route Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.test('Has trip', () => pm.expect(r.trip).to.be.an('object'));",
                  "pm.test('Has estimate', () => pm.expect(r.estimate).to.be.an('object'));",
                  "pm.test('Has breakdown array', () => pm.expect(r.breakdown).to.be.an('array'));",
                  "pm.test('Has fuel_stops array', () => pm.expect(r.fuel_stops).to.be.an('array'));",
                  "pm.test('Toll amount positive', () => pm.expect(r.estimate.toll_amount).to.be.above(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/trips/{{trip_id}}/route"
          }
        },
        {
          "name": "Get Trip - 404",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/trips/00000000-0000-0000-0000-000000000000"
          }
        },
        {
          "name": "No Auth - 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/trips"
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Summary",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const s = pm.response.json();",
                  "pm.test('total_trips >= 0', () => pm.expect(s.total_trips).to.be.at.least(0));",
                  "pm.test('total_toll_spend >= 0', () => pm.expect(s.total_toll_spend).to.be.at.least(0));",
                  "pm.test('avg_cost_per_trip >= 0', () => pm.expect(s.avg_cost_per_trip).to.be.at.least(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/analytics/summary"
          }
        },
        {
          "name": "Spend Over Time",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/analytics/spend"
          }
        },
        {
          "name": "Top Corridors",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const c = pm.response.json();",
                  "pm.test('Returns array', () => pm.expect(c).to.be.an('array'));",
                  "pm.test('Max 5 corridors', () => pm.expect(c.length).to.be.at.most(5));",
                  "if (c.length >= 2) {",
                  "  pm.test('Ordered by avg_toll desc', () => pm.expect(c[0].avg_toll).to.be.at.least(c[1].avg_toll));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/analytics/corridors"
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "List Vehicles",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const v = pm.response.json();",
                  "pm.test('Has 6 seeded vehicles', () => pm.expect(v.length).to.equal(6));",
                  "pm.test('Each has class', () => v.forEach(x => pm.expect(x.class).to.be.a('string')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/api/vehicles"
          }
        }
      ]
    }
  ]
}
